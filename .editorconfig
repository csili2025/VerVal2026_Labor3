root = true

[*.cs]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# nem futtat automatikus javitast
dotnet_analyzer_diagnostic.category-Style.severity = suggestion
 
# build error
#dotnet_diagnostic.IDE1006.severity = error